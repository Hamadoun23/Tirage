{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "fr",
  "version": "1.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://tiktok.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export Commentateurs TikTok"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
